# Copy this file to .env for local development and replace the example secret.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EXTENSION_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

POSTGRES_DB=focusos_db
POSTGRES_USER=focusos_user
POSTGRES_PASSWORD=focusos_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Set DATABASE_ENGINE=sqlite only for local tests without PostgreSQL.
DATABASE_ENGINE=

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_REMINDERS_MINUTE=*/30
CELERY_WEEKLY_SUMMARY_MINUTE=0
CELERY_WEEKLY_SUMMARY_HOUR=9
CELERY_WEEKLY_SUMMARY_DAY_OF_WEEK=mon
CELERY_DEEP_WORK_SUGGESTIONS_MINUTE=*/30
CELERY_EXPORT_CLEANUP_MINUTE=15
CELERY_EXPORT_CLEANUP_HOUR=3
CELERY_ACCOUNT_EXPORT_CLEANUP_MINUTE=45
CELERY_ACCOUNT_EXPORT_CLEANUP_HOUR=3
CELERY_ACCOUNT_DELETION_RECEIPT_CLEANUP_MINUTE=0
CELERY_ACCOUNT_DELETION_RECEIPT_CLEANUP_HOUR=4

OPENROUTER_API_KEY=<set-your-provider-key>
OPENROUTER_MODEL=llama-3.1-8b-instant
DOCUMENT_SUMMARY_MODEL=llama-3.1-8b-instant
FLASHCARD_GENERATION_MODEL=llama-3.1-8b-instant
OPENROUTER_BASE_URL=https://api.groq.com/openai/v1
AI_SEMANTIC_REALTIME_ENABLED=false

AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=2
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_COOLDOWN_SECONDS=120

SESSION_INSIGHT_TASK_MAX_RETRIES=3
SESSION_INSIGHT_TASK_RETRY_BACKOFF_SECONDS=60

AI_INSIGHT_MAX_RETRIES=2
AI_INSIGHT_RETRY_BACKOFF_SECONDS=45

SESSION_INSIGHT_MANUAL_RETRY_LIMIT=3
SESSION_INSIGHT_STALE_PROCESSING_SECONDS=1200

ACCOUNT_DELETION_STATUS_TOKEN_TTL_HOURS=24

REALTIME_SCORE_WINDOW_SECONDS=300
REALTIME_SCORE_STALE_SECONDS=90
REALTIME_SCORE_MIN_EVENTS=3
REALTIME_SCORE_TAB_SWITCH_PENALTY=8

WARNING_INTERVAL_SECONDS=10
WARNING_MAX_LEVEL=3


SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
