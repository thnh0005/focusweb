# Copy to .env before local Docker development.

DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=True
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EXTENSION_ALLOWED_ORIGINS=

DATABASE_ENGINE=postgres
POSTGRES_DB=focusos
POSTGRES_USER=focusos
POSTGRES_PASSWORD=focusos
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

AI_PROVIDER=openrouter
OPENROUTER_API_KEY=<set-your-provider-key>
OPENROUTER_MODEL=llama-3.1-8b-instant
DOCUMENT_SUMMARY_MODEL=llama-3.1-8b-instant
FLASHCARD_GENERATION_MODEL=llama-3.1-8b-instant
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
GROQ_MODEL=
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MAX_REQUEST_TOKENS=3700
AI_TARGET_REQUEST_TOKENS=3500
AI_CHUNK_OUTPUT_RESERVE_TOKENS=650
AI_REDUCTION_OUTPUT_RESERVE_TOKENS=700
AI_SUMMARY_OUTPUT_RESERVE_TOKENS=500
AI_KEY_POINTS_SUMMARY_OUTPUT_RESERVE_TOKENS=800
AI_DETAILED_SUMMARY_OUTPUT_RESERVE_TOKENS=1200
AI_FLASHCARD_OUTPUT_RESERVE_TOKENS=1100
AI_CONTEXT_SUMMARY_MAX_TOKENS=450
AI_ENTITY_MEMORY_MAX_TOKENS=250
AI_CHUNK_OVERLAP_TOKENS=120
AI_MIN_CURRENT_CHUNK_TOKENS=300
AI_MAX_RETRIES=0
AI_RETRY_BACKOFF_SECONDS=2
AI_SEMANTIC_REALTIME_ENABLED=false
DOCUMENT_EXTRACTION_STALE_SECONDS=900
DOCUMENT_UPLOADED_GRACE_SECONDS=120
DOCUMENT_EXTRACTION_MAX_RECOVERY_ATTEMPTS=2
AI_JOB_STALE_PROCESSING_SECONDS=900
AI_JOB_MAX_RECOVERY_ATTEMPTS=2
AI_STALE_RECOVERY_INTERVAL_SECONDS=300
AI_QUOTA_DEFER_MAX_RETRIES=120
AI_RATE_LIMITER_ENABLED=True
AI_RATE_LIMITER_REDIS_URL=redis://localhost:6379/0
AI_RATE_LIMITER_FAIL_OPEN=False
AI_PROVIDER_TOKEN_LIMIT_PER_MINUTE=6000
AI_PROVIDER_REQUEST_LIMIT_PER_MINUTE=30
AI_RATE_LIMITER_SAFETY_MARGIN=0.15
AI_RATE_LIMITER_FALLBACK_BACKOFF_SECONDS=60
AI_RATE_LIMITER_JITTER_SECONDS=5
AI_PROVIDER_WORKER_CONCURRENCY=1

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_MOCK_AUTH=false
NEXT_PUBLIC_EXTENSION_ID=
